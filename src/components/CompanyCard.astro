---
import type { Company } from "@/data/metrics";
interface Props {
  company: Company;
}
const { company: c } = Astro.props;
const down = c.dayChange.trim().startsWith("-");
const deltaColor = down ? "text-[color:var(--color-down)]" : "text-[color:var(--color-up)]";
---

<article class="flex flex-col rounded-2xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)]/70 p-5">
  <!-- ── header：身份 + 报价 ── -->
  <header class="flex items-start justify-between gap-3">
    <div class="flex items-start gap-3">
      <div class="flex shrink-0 -space-x-2">
        {c.logos.map((src, li) => (
          <span class="grid h-9 w-9 place-items-center overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-[color:var(--color-line)]" style={`z-index:${c.logos.length - li}`}>
            <img src={src} alt={`${c.name} logo`} width="36" height="36" loading="lazy" decoding="async" class="h-6 w-6 object-contain" />
          </span>
        ))}
      </div>
      <div>
        <h3 class="font-[family-name:var(--font-display)] text-xl font-bold tracking-tight text-[color:var(--color-ink)]">{c.name}</h3>
        <div class="mt-1 flex items-center gap-2 font-mono text-xs text-[color:var(--color-ink-mute)]">
          <span class="rounded bg-[color:var(--color-surface-2)] px-1.5 py-0.5">{c.ticker}</span>
          <span>{c.region}</span>
        </div>
        <div class="mt-2 flex flex-wrap gap-1.5">
          {c.focus.map((f) => (
            <span class="rounded-full border border-[color:var(--color-line)] px-2 py-0.5 text-[11px] text-[color:var(--color-ink-dim)]">{f}</span>
          ))}
        </div>
      </div>
    </div>
    <div class="text-right" data-quote={c.yf.join(",")}>
      <div class="flex items-center justify-end gap-1.5">
        <span class="hidden h-1.5 w-1.5 animate-pulse rounded-full bg-[color:var(--color-heat)]" data-q-live title="实时报价"></span>
        <span class="font-mono text-xl font-semibold tnum text-[color:var(--color-ink)]" data-q-price>{c.last}</span>
      </div>
      <div class={`font-mono text-sm tnum ${deltaColor}`} data-q-day>{c.dayChange}</div>
      <div class="mt-0.5 font-mono text-[11px] tnum text-[color:var(--color-up)]" data-q-ytd>YTD {c.ytd}</div>
      <div data-spark={c.yf[0]} class="mt-1.5 ml-auto h-7 w-24" aria-hidden="true"></div>
    </div>
  </header>

  <!-- ── 双栏：左 = 财务/实时，右 = 监控信号 ── -->
  <div class="mt-4 grid gap-5 border-t border-[color:var(--color-line-soft)] pt-4 sm:grid-cols-2">
    <!-- 左栏 -->
    <div class="space-y-3">
      <!-- 实时财务（载入后显示）-->
      <div data-fund={c.yf.join(",")} class="hidden rounded-xl border border-[color:var(--color-heat)]/25 bg-[color:var(--color-heat)]/[0.04] p-4">
        <div class="mb-3.5 flex items-center gap-2">
          <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-[color:var(--color-heat)]"></span>
          <span class="text-[11px] font-semibold uppercase tracking-wider text-[color:var(--color-heat)]">实时 · Yahoo</span>
          <span data-fund-time class="ml-auto font-mono text-[10px] text-[color:var(--color-ink-mute)]"></span>
        </div>

        <!-- 财报 -->
        <div class="text-[10px] font-medium uppercase tracking-wider text-[color:var(--color-ink-mute)]">最新财报</div>
        <div class="mt-2 grid grid-cols-2 gap-x-4 gap-y-3">
          <div>
            <div class="text-[10px] text-[color:var(--color-ink-mute)]">报告季末</div>
            <div data-fund-qend class="mt-0.5 font-mono text-[13px] text-[color:var(--color-ink)]">—</div>
          </div>
          <div>
            <div data-fund-elabel class="text-[10px] text-[color:var(--color-ink-mute)]">财报日</div>
            <div data-fund-edate class="mt-0.5 font-mono text-[13px] text-[color:var(--color-ink)]">—</div>
          </div>
          <div>
            <div class="text-[10px] text-[color:var(--color-ink-mute)]">当季营收</div>
            <div data-fund-qrev class="mt-0.5 font-mono text-[13px] text-[color:var(--color-ink)]">—</div>
          </div>
          <div>
            <div class="text-[10px] text-[color:var(--color-ink-mute)]">净利率</div>
            <div data-fund-qnm class="mt-0.5 font-mono text-[13px] text-[color:var(--color-ink)]">—</div>
          </div>
        </div>

        <!-- 共识 -->
        <div class="mt-3.5 flex items-center gap-2 border-t border-[color:var(--color-heat)]/12 pt-3.5">
          <span class="text-[10px] font-medium uppercase tracking-wider text-[color:var(--color-ink-mute)]">分析师共识</span>
          <span data-fund-rec class="ml-auto rounded-md bg-[color:var(--color-surface-2)] px-2 py-0.5 text-[11px] font-semibold"></span>
        </div>
        <div class="mt-2 grid grid-cols-2 gap-x-4 gap-y-3">
          <div>
            <div class="text-[10px] text-[color:var(--color-ink-mute)]">共识目标</div>
            <div data-fund-target class="mt-0.5 font-mono text-[15px] font-semibold text-[color:var(--color-ink)]">—</div>
          </div>
          <div>
            <div class="text-[10px] text-[color:var(--color-ink-mute)]">分析师</div>
            <div data-fund-n class="mt-0.5 font-mono text-[13px] text-[color:var(--color-ink)]">—</div>
          </div>
        </div>
        <div class="mt-2.5 space-y-1 text-[11px] leading-relaxed text-[color:var(--color-ink-mute)]">
          <div>目标区间 <span data-fund-range class="font-mono text-[color:var(--color-ink-dim)]">—</span></div>
          <div data-fund-fin></div>
        </div>

        <!-- 估值 -->
        <div class="mt-3.5 border-t border-[color:var(--color-heat)]/12 pt-3.5 text-[10px] font-medium uppercase tracking-wider text-[color:var(--color-ink-mute)]">估值</div>
        <div class="mt-2 grid grid-cols-2 gap-x-4 gap-y-3">
          <div>
            <div class="text-[10px] text-[color:var(--color-ink-mute)]">市值</div>
            <div data-fund-mcap class="mt-0.5 font-mono text-[13px] text-[color:var(--color-ink)]">—</div>
          </div>
          <div>
            <div class="text-[10px] text-[color:var(--color-ink-mute)]">远期 P/E</div>
            <div data-fund-fpe class="mt-0.5 font-mono text-[13px] text-[color:var(--color-ink)]">—</div>
          </div>
        </div>
        <div class="mt-2.5 text-[11px] text-[color:var(--color-ink-mute)]">距 52 周高 <span data-fund-52w class="font-mono text-[color:var(--color-ink-dim)]">—</span></div>
      </div>

      <!-- 5/19 研报快照 -->
      {(c.earnings?.highlight || c.targets.length > 0) && (
        <div class="text-[11px] leading-relaxed">
          <div class="mb-1.5 flex items-center gap-1.5 uppercase tracking-wider text-[color:var(--color-ink-mute)]">
            <span>◷</span><span class="text-[10px]">5/19 研报</span>
          </div>
          {c.earnings?.highlight && (
            <p class="text-[color:var(--color-ink-dim)]">{c.earnings.highlight}</p>
          )}
          {c.targets.length > 0 && (
            <div class="mt-1.5 flex flex-wrap gap-1.5">
              {c.targets.map((t) => (
                <span class="rounded-md border border-[color:var(--color-line-soft)] px-2 py-1">
                  <span class="font-mono font-semibold tnum text-[color:var(--color-ink)]">{t.target}</span>
                  <span class="text-[color:var(--color-ink-mute)]"> {t.bank}</span>
                </span>
              ))}
            </div>
          )}
        </div>
      )}
    </div>

    <!-- 右栏：核心监控信号（全部 6 条）-->
    <div>
      <div class="mb-2.5 text-[10px] uppercase tracking-wider text-[color:var(--color-ink-mute)]">核心监控信号</div>
      <ul class="space-y-2.5">
        {c.metrics.map((m) => (
          <li class="grid grid-cols-[18px_1fr] gap-2">
            <span class="mt-0.5 font-mono text-[11px] text-[color:var(--color-ink-mute)]/60">{String(m.id).padStart(2, "0")}</span>
            <div>
              <p class="text-[13px] font-medium leading-snug text-[color:var(--color-ink)]">{m.name}</p>
              <p class="mt-0.5 text-[11px] leading-snug text-[color:var(--color-ink-mute)]">
                <span class="text-[color:var(--color-heat)]/80">→</span> {m.status}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</article>
