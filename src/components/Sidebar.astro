---
import CycleArc from "./CycleArc.astro";
import { META } from "@/data/metrics";

const nav = [
  { id: "overview", label: "概览", n: "00" },
  { id: "companies", label: "企业", n: "01" },
  { id: "industry", label: "行业", n: "02" },
  { id: "prices", label: "价格", n: "03" },
  { id: "events", label: "事件", n: "04" },
];
---

<!-- ── 桌面：固定左栏 ── -->
<aside class="fixed inset-y-0 left-0 z-30 hidden w-[248px] flex-col border-r border-[color:var(--color-line)] bg-[color:var(--color-bg)]/80 px-6 py-7 backdrop-blur lg:flex">
  <a href="#overview" class="group flex items-center gap-2.5">
    <span class="grid h-8 w-8 place-items-center rounded-md border border-[color:var(--color-line)] bg-[color:var(--color-surface)]">
      <span class="h-3 w-3 rounded-sm bg-[color:var(--color-heat)]"></span>
    </span>
    <span class="font-[family-name:var(--font-display)] text-sm font-bold uppercase tracking-[0.15em] text-[color:var(--color-ink)]">
      Storage<span class="text-[color:var(--color-heat)]">Cycle</span>
    </span>
  </a>

  <!-- 迷你周期表 -->
  <div class="mt-7 rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)]/50 p-4">
    <div class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-ink-mute)]">周期位置</div>
    <div class="mt-1 flex items-baseline gap-1">
      <span class="font-mono text-3xl font-bold tnum text-[color:var(--color-heat)]">65</span>
      <span class="font-mono text-sm text-[color:var(--color-ink-mute)]">%</span>
    </div>
    <div class="mt-2 -mb-1">
      <CycleArc value={65} size={180} showLabels={false} id="mini" />
    </div>
    <p class="mt-1 text-[11px] leading-snug text-[color:var(--color-ink-mute)]">上行中段 · 四指标均未见顶</p>
  </div>

  <!-- 章节导航 -->
  <nav class="mt-7 flex-1" aria-label="章节">
    <ul class="space-y-0.5">
      {nav.map((item) => (
        <li>
          <a
            href={`#${item.id}`}
            data-nav={item.id}
            class="nav-link group flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-[color:var(--color-ink-mute)] transition-colors hover:text-[color:var(--color-ink)]"
          >
            <span class="nav-bar h-4 w-[2px] rounded-full bg-transparent transition-colors"></span>
            <span class="font-mono text-[11px] text-[color:var(--color-ink-mute)]/70">{item.n}</span>
            <span>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- 开源 · GitHub -->
  <a
    href="https://github.com/chyyynh/storagecycle"
    target="_blank"
    rel="noopener noreferrer"
    class="group mb-4 flex items-center gap-2.5 rounded-lg border border-[color:var(--color-line)] bg-[color:var(--color-surface)]/50 px-3 py-2.5 text-sm text-[color:var(--color-ink-dim)] transition-colors hover:border-[color:var(--color-heat)]/50 hover:text-[color:var(--color-ink)]"
  >
    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.36 9.36 0 0 1 12 6.84c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/>
    </svg>
    <div class="leading-tight">
      <div class="font-medium">开源 · GitHub</div>
      <div class="text-[10px] text-[color:var(--color-ink-mute)]">欢迎 Star、提建议</div>
    </div>
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto text-[color:var(--color-ink-mute)] transition-colors group-hover:text-[color:var(--color-heat)]" aria-hidden="true">
      <path d="M7 17 17 7M7 7h10v10"/>
    </svg>
  </a>

  <div class="border-t border-[color:var(--color-line)] pt-4 text-[11px] text-[color:var(--color-ink-mute)]">
    <div class="mb-1 uppercase tracking-wider">数据来源</div>
    <div class="leading-relaxed">{META.sources.map((s) => s.name).join(" · ")}</div>
    <div class="mt-2 font-mono">更新 {META.updated}</div>
  </div>
</aside>

<!-- ── 移动：顶部章节 chips ── -->
<div class="sticky top-0 z-30 border-b border-[color:var(--color-line)] bg-[color:var(--color-bg)]/90 backdrop-blur lg:hidden">
  <div class="flex items-center justify-between px-4 py-3">
    <span class="font-[family-name:var(--font-display)] text-sm font-bold uppercase tracking-[0.15em]">
      Storage<span class="text-[color:var(--color-heat)]">Cycle</span>
    </span>
    <div class="flex items-center gap-3">
      <span class="font-mono text-xs text-[color:var(--color-ink-mute)]">周期 <span class="font-bold text-[color:var(--color-heat)]">65%</span></span>
      <a href="https://github.com/chyyynh/storagecycle" target="_blank" rel="noopener noreferrer" aria-label="GitHub（开源 · 欢迎建议）" class="text-[color:var(--color-ink-mute)] transition-colors hover:text-[color:var(--color-ink)]">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.36 9.36 0 0 1 12 6.84c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/>
        </svg>
      </a>
    </div>
  </div>
  <nav class="flex gap-1 overflow-x-auto px-4 pb-2.5" aria-label="章节">
    {nav.map((item) => (
      <a href={`#${item.id}`} data-nav={item.id}
        class="nav-link whitespace-nowrap rounded-full border border-[color:var(--color-line)] px-3 py-1 text-xs text-[color:var(--color-ink-mute)]">
        {item.label}
      </a>
    ))}
  </nav>
</div>

<script>
  // 滚动监听：高亮当前章节
  const links = Array.from(document.querySelectorAll<HTMLElement>(".nav-link"));
  const byId = (id: string) => links.filter((l) => l.dataset.nav === id);
  const setActive = (id: string) => {
    links.forEach((l) => {
      const on = l.dataset.nav === id;
      l.classList.toggle("text-[color:var(--color-ink)]", on);
      l.classList.toggle("bg-[color:var(--color-surface)]", on && l.querySelector(".nav-bar") !== null);
      const bar = l.querySelector<HTMLElement>(".nav-bar");
      if (bar) bar.style.background = on ? "var(--color-heat)" : "transparent";
      if (!l.querySelector(".nav-bar")) {
        l.style.borderColor = on ? "var(--color-heat)" : "";
        l.style.color = on ? "var(--color-ink)" : "";
      }
    });
  };
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) setActive((e.target as HTMLElement).dataset.section || "");
      });
    },
    { rootMargin: "-45% 0px -50% 0px" }
  );
  document.querySelectorAll("[data-section]").forEach((s) => obs.observe(s));
</script>
