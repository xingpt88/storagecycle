---
interface Props {
  id: string;
  eyebrow: string; // 章节序号/类别
  title: string;
  desc?: string;
}
const { id, eyebrow, title, desc } = Astro.props;
---

<section id={id} data-section={id} class="scroll-mt-8 py-12 first:pt-4">
  <div class="mb-7 flex items-end justify-between gap-4 border-b border-[color:var(--color-line)] pb-4">
    <div>
      <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-[color:var(--color-heat)]">
        {eyebrow}
      </div>
      <h2 class="mt-1.5 font-[family-name:var(--font-display)] text-2xl font-bold tracking-tight text-[color:var(--color-ink)] sm:text-3xl">
        {title}
      </h2>
      {desc && <p class="mt-1.5 max-w-2xl text-sm text-[color:var(--color-ink-mute)]">{desc}</p>}
    </div>
  </div>
  <slot />
</section>
