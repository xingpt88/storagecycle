{
	"name": "storage-cycle-scraper",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-24",
	"compatibility_flags": ["nodejs_compat"],
	// 仅 cron 定时触发，不需要 workers.dev HTTP 路由
	"workers_dev": false,
	"observability": {
		"enabled": true,
	},
	// 每日 02:00 UTC 爬一次
	"triggers": {
		"crons": ["0 2 * * *"],
	},
	// 与 Pages 共用同一个 D1（Pages 读、本 Worker 写）
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "storage-cycle-prices",
			"database_id": "56bae37c-823c-405d-8a99-e44177b00d95",
		},
	],
}
